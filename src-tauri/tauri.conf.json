{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ExaTon Next",
  "version": "1.1.1",
  "identifier": "net.rimaki.exatonext",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "removeUnusedCommands": false
  },
  "app": {
    "windows": [
      {
        "title": "ExaTon NEXT",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist"
    }
  }
}
